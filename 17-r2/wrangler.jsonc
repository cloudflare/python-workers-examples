{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "python-r2",
	"main": "src/entry.py",
	"compatibility_date": "2025-11-02",
	"compatibility_flags": [
		"python_workers"
	],
	"r2_buckets": [
		{
			"binding": "BUCKET",
			"bucket_name": "python-r2-example"
		}
	],
	"observability": {
		"enabled": true
	}
}
